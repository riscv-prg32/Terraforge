  "abi": "prg32-colophon-1.0",
  "title": "TerraForge 32 3D",
  "subtitle": "Original first-person block cavern",
  "version": "1.0.0",
  "release_date": "2026-06-11",
  "developer": {
    "name": "UniParthenope PRG32",
