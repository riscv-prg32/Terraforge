    "Original clean-room code, art, audio, and procedural content for PRG32 teaching."
  ],
  "controls": [
    {
      "input": "D-pad left/right",
      "action": "Rotate the first-person camera"
    },
    {
      "input": "D-pad up/down",
      "action": "Move forward or backward"
    },
    {
      "input": "A",
      "action": "Dig the targeted block"
    },
    {
      "input": "Down + A",
      "action": "Place the selected inventory block"
    },
    {
      "input": "B",
      "action": "Run while moving or cycle the selected block"
    },
    {
      "input": "START",
      "action": "Restart the generated cavern"
    }
  ],
  "start_prompt": "Recover four crystal relics before health reaches zero"
}
